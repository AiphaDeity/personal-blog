# ========== Python 运行缓存 ==========
# Python 自动生成的字节码缓存文件夹，完全不需要提交
__pycache__/
# 所有 .pyc 后缀的字节码文件
*.pyc
*.pyo
*.pyd

# ========== 虚拟环境 ==========
# 本地 Python 虚拟环境目录，每个人环境不一样，不需要提交
venv/
env/
.venv/
env.bak/
venv.bak/

# ========== 项目本地数据 ==========
# Flask 实例文件夹，存放本地数据库、私密配置，绝对不能提交
instance/
*.db
*.sqlite
*.sqlite3

# 环境变量配置文件，存秘钥、密码，提交了会泄露安全信息
.env
.env.local
.env.*.local

# ========== 日志文件 ==========
*.log
logs/

# ========== 编辑器/IDE 配置 ==========
# VS Code 本地配置
.vscode/
# PyCharm 本地配置
.idea/
*.swp
*.swo

# ========== 系统垃圾文件 ==========
# Mac 系统自动生成的文件
.DS_Store
# Windows 系统缩略图缓存
Thumbs.db